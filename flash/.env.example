# RunPod auth (or use: flash login)
# RUNPOD_API_KEY=your_runpod_api_key

# Single combined KYC worker image (GHCR)
FLASH_KYC_IMAGE=ghcr.io/yzaicev/glm-ocr-serverless:main
FLASH_LLM_MODEL_ID=Qwen/Qwen2.5-3B-Instruct

# Scaling
FLASH_KYC_WORKERS_MIN=0
FLASH_KYC_WORKERS_MAX=1
FLASH_IDLE_TIMEOUT_SECONDS=60

# Storage / timeouts
FLASH_KYC_CONTAINER_DISK_GB=40
FLASH_KYC_TIMEOUT_MS=300000
FLASH_WORKER_TORCH_DTYPE=float16

# Flash dev server
# FLASH_HOST=localhost
# FLASH_PORT=8888
