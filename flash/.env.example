# RunPod auth (or use: flash login)
# RUNPOD_API_KEY=your_runpod_api_key

# Docker images (GHCR)
FLASH_OCR_IMAGE=ghcr.io/yzaicev/glm-ocr-serverless:main
FLASH_LLM_IMAGE=ghcr.io/yzaicev/glm-ocr-serverless-llm:main

# Scaling
FLASH_WORKERS_MIN=0
FLASH_WORKERS_MAX=3
FLASH_IDLE_TIMEOUT_SECONDS=60

# Storage / timeouts
FLASH_OCR_CONTAINER_DISK_GB=30
FLASH_LLM_CONTAINER_DISK_GB=40
FLASH_OCR_TIMEOUT_MS=120000
FLASH_LLM_TIMEOUT_MS=300000

# Flash dev server
# FLASH_HOST=localhost
# FLASH_PORT=8888
