# RunPod auth (or use: flash login)
# RUNPOD_API_KEY=your_runpod_api_key

# Docker images (GHCR)
FLASH_OCR_IMAGE=ghcr.io/yzaicev/glm-ocr-serverless:main
FLASH_LLM_IMAGE=ghcr.io/yzaicev/glm-ocr-serverless-llm:main

# Scaling (sum of *_WORKERS_MAX must fit your RunPod quota, default account = 10 total)
FLASH_OCR_WORKERS_MIN=0
FLASH_OCR_WORKERS_MAX=2
FLASH_LLM_WORKERS_MIN=0
FLASH_LLM_WORKERS_MAX=1
FLASH_ORCHESTRATOR_WORKERS_MIN=0
FLASH_ORCHESTRATOR_WORKERS_MAX=1
FLASH_ORCHESTRATOR_TIMEOUT_MS=600000
FLASH_WORKER_TORCH_DTYPE=float16
FLASH_IDLE_TIMEOUT_SECONDS=60

# Storage / timeouts
FLASH_OCR_CONTAINER_DISK_GB=30
FLASH_LLM_CONTAINER_DISK_GB=40
FLASH_OCR_TIMEOUT_MS=120000
FLASH_LLM_TIMEOUT_MS=300000

# Flash dev server
# FLASH_HOST=localhost
# FLASH_PORT=8888
